# ─────────────────────────────────────────────────────────────
#  Supplement Bank — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values below.
#   cp .env.local.example .env.local
#
# You get the Project ID + Dataset from https://www.sanity.io/manage
# after creating a (free) Sanity project.
# ─────────────────────────────────────────────────────────────

# The Sanity project ID (found in sanity.io/manage → Project → API).
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"

# The dataset name. Usually "production".
NEXT_PUBLIC_SANITY_DATASET="production"

# The Sanity API version (a date). Keep as-is unless you know you need a newer one.
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"

# OPTIONAL: WhatsApp number fallback if Site Settings is not filled in Sanity.
# Format: country code + number, digits only. e.g. 919876543210
NEXT_PUBLIC_DEFAULT_WHATSAPP_NUMBER="91XXXXXXXXXX"

# OPTIONAL: The canonical site URL, used for SEO / Open Graph / sitemap.
NEXT_PUBLIC_SITE_URL="https://supplementbank.example.com"
